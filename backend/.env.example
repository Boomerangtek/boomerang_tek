# Node Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/emissionbot?sslmode=require

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# APIs
BIRDEYE_API_KEY=your_birdeye_api_key

// Frontend URL (for dashboard links in Telegram)
FRONTEND_URL=http://localhost:3001

# Boomerang Token Address (for homepage stats)
BOOMERANG_TOKEN_ADDRESS=your_boomerang_token_address_here

# Security - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=your_64_character_hex_string_here
